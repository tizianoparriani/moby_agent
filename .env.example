APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET=dev_secret_token

# Claude
CLAUDE_API_KEY=replace_me

# MinIO (S3 compatibile)
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminadmin
MINIO_BUCKET=docs
MINIO_REGION=us-east-1

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chunks

# Meilisearch
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=master_key_dev
MEILISEARCH_INDEX=documents

# Auth & user management
JWT_SECRET=change_me_in_production
JWT_EXPIRE_HOURS=168
DAILY_QUERY_LIMIT=10
# Admin account seeded on startup (leave empty to skip)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
DB_PATH=/data/moby.db

# UI
UI_PORT=8501
