FROM python:3.11-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl wget ca-certificates && rm -rf /var/lib/apt/lists/*

# CPU-only PyTorch (avoids the ~2GB CUDA wheel pulled in by sentence-transformers)
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# Python deps (RAG pipeline + API)
COPY apps/api/requirements.txt /app/apps/api/requirements.txt
RUN pip install --no-cache-dir -r /app/apps/api/requirements.txt

# Bake the embedding model into the image (COPY from local export — no HF Hub at build time).
# Export on host first: python -c "from sentence_transformers import SentenceTransformer; \
#   SentenceTransformer('BAAI/bge-m3').save('infra/compose/bge-m3-model')"
COPY infra/compose/bge-m3-model /models/bge-m3

# App code (last, so code changes don't invalidate the heavy layers above)
COPY apps/api /app/apps/api
COPY infra/init /app/infra/init

ENV PYTHONUNBUFFERED=1 \
    EMBEDDING_MODEL=/models/bge-m3 \
    HF_HUB_DISABLE_TELEMETRY=1
EXPOSE 8000

CMD ["uvicorn", "apps.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
