FROM python:3.11-slim

WORKDIR /app

COPY apps/ui/requirements.txt /app/apps/ui/requirements.txt
RUN pip install --no-cache-dir -r /app/apps/ui/requirements.txt

COPY apps/ui /app/apps/ui

EXPOSE 8501
CMD ["streamlit", "run", "apps/ui/app.py", "--server.port=8501", "--server.address=0.0.0.0"]
